# todo: Заданы три числа в переменных x, y, z.
# Напечатать наибольшее из этих чисел.
# Пример:
x = 10
y = 15
z = 2
# Ответ:
# Наибольшее число 15

largest_value = max(x, y, z)
print(f"Наибольшее число:{largest_value}")

